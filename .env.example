# Copy to .env and fill in your LLM credentials:  cp .env.example .env
# Any OpenAI-compatible /v1/chat/completions endpoint works.

# LLM settings (OpenAI-compatible)
# Base URL WITHOUT the trailing /chat/completions.
LLM_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=openai/gpt-oss-120b:free
LLM_API_KEY=sk-replace-me
LLM_TIMEOUT_SECONDS=30
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=1024

# Database settings
# Overridden by docker-compose for the `api` service; set here for local runs.
DATABASE_URL=postgresql://assistant_ro:assistant_ro@localhost:5432/analytics
DB_STATEMENT_TIMEOUT_MS=10000
DB_POOL_MIN_SIZE=1
DB_POOL_MAX_SIZE=5

# Query policy
DEFAULT_MAX_ROWS=100
MAX_ROWS_LIMIT=1000
CACHE_SCHEMA=true
SQL_GENERATION_MAX_ATTEMPTS=2
SQL_QUALITY_STRICT=false
SQL_QUALITY_MAX_JOINS=6
SQL_QUALITY_MAX_SUBQUERIES=8
SQL_QUALITY_DISALLOW_SELECT_STAR_WITH_JOIN=true

# Cost guard policy (EXPLAIN preflight)
DB_EXPLAIN_PREFLIGHT_ENABLED=true
DB_EXPLAIN_STRICT=false
DB_EXPLAIN_MAX_TOTAL_COST=500000
DB_EXPLAIN_MAX_PLAN_ROWS=5000000

# App settings
LOG_LEVEL=INFO
METRICS_ENABLED=true
